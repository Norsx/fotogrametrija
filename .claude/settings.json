{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python .ai/scripts/hooks/protect_raw.py",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .ai/scripts/hooks/git_checkpoint_gate.py",
            "timeout": 20
          }
        ]
      }
    ]
  }
}

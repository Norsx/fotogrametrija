# LiteRealm Environment Configuration

# Google Gemini API key (optional). RAG uses it for cloud embeddings when set;
# otherwise it falls back to local sentence-transformers. RAG works either way.
# GEMINI_API_KEY=your-api-key-here

# Path to the Global Brain knowledge base (shared across all projects)
# Used by bootstrap scripts and DevContainer mounts.
# Default: ~/.agentbrain (Linux/macOS) or %USERPROFILE%\.agentbrain (Windows)
AGENTBRAIN_PATH=~/.agentbrain

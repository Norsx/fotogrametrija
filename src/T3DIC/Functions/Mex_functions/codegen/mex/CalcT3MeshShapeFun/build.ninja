# CompilerName=msvcpp170
# Mode=optim
ninja_required_version = 1.3

# Basic folders
root = .
builddir = $root\build\win64
matlabdir = C:\Program Files\MATLAB\R2024a
startdir = C:\Users\Admin\OneDrive - Fakultet strojarstva i brodogradnje\Work\Matlab\T3DIC\Functions\Mex_functions

# Toolchain information
cc = cl
cxx = cl
linker = link
linkerxx = link

cflags =  /c /Zc:__cplusplus /Zp8 /GR /W3 /EHs /nologo /MD /D_CRT_SECURE_NO_DEPRECATE /D_SCL_SECURE_NO_DEPRECATE /D_SECURE_SCL=0   /DMATLAB_MEX_FILE  /DMATLAB_MEX_FILE /O2 /Oy- /DNDEBUG /fp:strict /utf-8 /I "$root" /I "$startdir" /I "$root\interface" /I "$matlabdir\extern\include" /I "." -DMODEL=CalcT3MeshShapeFun_mex -DMW_NEEDS_VERSION_H /wd4251 

cxxflags =   /c /Zc:__cplusplus /Zp8 /GR /W3 /EHs /nologo /MD /D_CRT_SECURE_NO_DEPRECATE /D_SCL_SECURE_NO_DEPRECATE /D_SECURE_SCL=0   /DMATLAB_MEX_FILE  /DMATLAB_MEX_FILE /O2 /Oy- /DNDEBUG /fp:strict /utf-8 /I "$root" /I "$startdir" /I "$root\interface" /I "$matlabdir\extern\include" /I "." -DMODEL=CalcT3MeshShapeFun_mex -DMW_NEEDS_VERSION_H /wd4251 

ldflags =  /nologo    /DLL /LIBPATH:"$matlabdir\extern\lib\win64\microsoft" libmx.lib libmex.lib libmat.lib kernel32.lib user32.lib gdi32.lib winspool.lib comdlg32.lib advapi32.lib shell32.lib ole32.lib oleaut32.lib uuid.lib odbc32.lib odbccp32.lib libMatlabDataArray.lib libMatlabEngine.lib  /out:"CalcT3MeshShapeFun_mex.mexw64" /LIBPATH:"$matlabdir\extern\lib\win64\microsoft" libmwblas.lib libemlrt.lib libcovrt.lib libut.lib libmwmathutil.lib 

linkobjs = 

# Build Rules
rule cc
    command = $cc $cflags $in /Fo$out

rule cxx
    command = $cxx $cxxflags $in /Fo$out

rule link
    command = $linker @$out.rsp $linkobjs $ldflags
    rspfile = $out.rsp
    rspfile_content = $in

rule linkxx
    command = $linkerxx $in $linkobjs $ldflags

# Build
build $builddir\CalcT3MeshShapeFun_data.obj : cxx $root\CalcT3MeshShapeFun_data.cpp
build $builddir\rt_nonfinite.obj : cxx $root\rt_nonfinite.cpp
build $builddir\CalcT3MeshShapeFun_initialize.obj : cxx $root\CalcT3MeshShapeFun_initialize.cpp
build $builddir\CalcT3MeshShapeFun_terminate.obj : cxx $root\CalcT3MeshShapeFun_terminate.cpp
build $builddir\CalcT3MeshShapeFun.obj : cxx $root\CalcT3MeshShapeFun.cpp
build $builddir\sparse.obj : cxx $root\sparse.cpp
build $builddir\indexShapeCheck.obj : cxx $root\indexShapeCheck.cpp
build $builddir\T3ElementShapeFun_V2.obj : cxx $root\T3ElementShapeFun_V2.cpp
build $builddir\warning.obj : cxx $root\warning.cpp
build $builddir\bigProduct.obj : cxx $root\bigProduct.cpp
build $builddir\validateNumericIndex.obj : cxx $root\validateNumericIndex.cpp
build $builddir\locBsearch.obj : cxx $root\locBsearch.cpp
build $builddir\_coder_CalcT3MeshShapeFun_api.obj : cxx $root\interface\_coder_CalcT3MeshShapeFun_api.cpp
build $builddir\_coder_CalcT3MeshShapeFun_mex.obj : cxx $root\interface\_coder_CalcT3MeshShapeFun_mex.cpp
build $builddir\eml_int_forloop_overflow_check.obj : cxx $root\eml_int_forloop_overflow_check.cpp
build $builddir\sortSparseParenAssignInputs.obj : cxx $root\sortSparseParenAssignInputs.cpp
build $builddir\sort.obj : cxx $root\sort.cpp
build $builddir\sortIdx.obj : cxx $root\sortIdx.cpp
build $builddir\sparse1.obj : cxx $root\sparse1.cpp
build $builddir\CalcT3MeshShapeFun_mexutil.obj : cxx $root\CalcT3MeshShapeFun_mexutil.cpp
build $builddir\_coder_CalcT3MeshShapeFun_info.obj : cxx $root\interface\_coder_CalcT3MeshShapeFun_info.cpp
build $builddir\cpp_mexapi_version.obj : cxx $matlabdir\extern\version\cpp_mexapi_version.cpp

# Link
build $root\CalcT3MeshShapeFun_mex.mexw64 : linkxx $builddir\CalcT3MeshShapeFun_data.obj $builddir\rt_nonfinite.obj $builddir\CalcT3MeshShapeFun_initialize.obj $builddir\CalcT3MeshShapeFun_terminate.obj $builddir\CalcT3MeshShapeFun.obj $builddir\sparse.obj $builddir\indexShapeCheck.obj $builddir\T3ElementShapeFun_V2.obj $builddir\warning.obj $builddir\bigProduct.obj $builddir\validateNumericIndex.obj $builddir\locBsearch.obj $builddir\_coder_CalcT3MeshShapeFun_api.obj $builddir\_coder_CalcT3MeshShapeFun_mex.obj $builddir\eml_int_forloop_overflow_check.obj $builddir\sortSparseParenAssignInputs.obj $builddir\sort.obj $builddir\sortIdx.obj $builddir\sparse1.obj $builddir\CalcT3MeshShapeFun_mexutil.obj $builddir\_coder_CalcT3MeshShapeFun_info.obj $builddir\cpp_mexapi_version.obj 
